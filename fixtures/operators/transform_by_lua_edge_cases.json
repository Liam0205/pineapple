{
  "operator": "transform_by_lua",
  "_comment": "Numeric-string cases (#175) here pin VALUE-level parity only: the Go/Java operator-fixture comparators stringify non-float values, so a pure type drift ('42' string vs 42 number) is invisible to them. Type identity is pinned by TransformByLuaTypeIdentityTest (assertInstanceOf) and by fixtures/pipelines/lua_string_number_identity.json via cross-validate's type-preserving JSON comparison.",
  "cases": [
    {
      "name": "float precision: 0.1 + 0.2",
      "params": {
        "lua_script": "function add_floats()\n  return 0.1 + 0.2\nend",
        "function_for_item": "add_floats",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": 0.30000000000000004}]
      }
    },
    {
      "name": "large integer near int64 max",
      "params": {
        "lua_script": "function large_int()\n  return 9007199254740992\nend",
        "function_for_item": "large_int",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": 9007199254740992}]
      }
    },
    {
      "name": "negative zero",
      "params": {
        "lua_script": "function neg_zero()\n  return -0.0\nend",
        "function_for_item": "neg_zero",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": -0}]
      }
    },
    {
      "name": "string to number coercion via arithmetic",
      "params": {
        "lua_script": "function str_math()\n  return \"42\" + 0\nend",
        "function_for_item": "str_math",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": 42}]
      }
    },
    {
      "name": "numeric string stays a string: 19-digit ID above 2^53 (issue #175)",
      "params": {
        "lua_script": "function big_id()\n  return \"1777288596209286259\"\nend",
        "function_for_item": "big_id",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": "1777288596209286259"}]
      }
    },
    {
      "name": "numeric string stays a string: 2^53+1 boundary (issue #175)",
      "params": {
        "lua_script": "function boundary_id()\n  return \"9007199254740993\"\nend",
        "function_for_item": "boundary_id",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": "9007199254740993"}]
      }
    },
    {
      "name": "numeric string stays a string: leading zeros preserved (issue #175)",
      "params": {
        "lua_script": "function padded_id()\n  return \"007\"\nend",
        "function_for_item": "padded_id",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": "007"}]
      }
    },
    {
      "name": "table of numeric strings survives byte-exact (issue #175)",
      "params": {
        "lua_script": "function id_table()\n  return {\"1777288596209286259\", \"9007199254740993\", \"007\"}\nend",
        "function_for_item": "id_table",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": ["1777288596209286259", "9007199254740993", "007"]}]
      }
    },
    {
      "name": "number to string via concatenation",
      "params": {
        "lua_script": "function num_concat()\n  return 3.14 .. \"\"\nend",
        "function_for_item": "num_concat",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": "3.14"}]
      }
    },
    {
      "name": "integer division (floor)",
      "params": {
        "lua_script": "function int_div()\n  return math.floor(7/2)\nend",
        "function_for_item": "int_div",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": 3}]
      }
    },
    {
      "name": "modulo with negative operand",
      "params": {
        "lua_script": "function neg_mod()\n  return -7 % 3\nend",
        "function_for_item": "neg_mod",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": 2}]
      }
    },
    {
      "name": "string length with multibyte (ASCII only)",
      "params": {
        "lua_script": "function str_len()\n  return string.len(\"hello\")\nend",
        "function_for_item": "str_len",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"y": 5}]
      }
    },
    {
      "name": "multiple return values",
      "params": {
        "lua_script": "function multi_ret()\n  return 10, 20, 30\nend",
        "function_for_item": "multi_ret",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["a", "b", "c"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{"a": 10, "b": 20, "c": 30}]
      }
    },
    {
      "name": "nil return means no write",
      "params": {
        "lua_script": "function bool_nil()\n  return nil\nend",
        "function_for_item": "bool_nil",
        "function_for_common": ""
      },
      "metadata": {
        "common_input": [],
        "common_output": [],
        "item_input": ["x"],
        "item_output": ["y"]
      },
      "input": {
        "common": {},
        "items": [{"x": 1}]
      },
      "expected": {
        "items": [{}]
      }
    }
  ]
}
