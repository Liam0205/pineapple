        }
      },
      "pipeline_map": {
        "stage": {"pipeline": ["stage"]}
      }
    },
    "pipeline_group": {
      "main": {"pipeline": ["stage"]}
    },
    "flow_contract": {
      "common_input": [],
      "item_input": ["x"],
      "common_output": [],
      "item_output": ["x"]
    }
  },
  "expected_error": {
