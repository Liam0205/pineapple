          "function_for_item": "nan_test",
          "function_for_common": "",
          "$metadata": {
            "common_input": [],
            "common_output": [],
            "item_input": ["x"],
            "item_output": ["y"]
          }
        }
      }
    },
    "pipeline_group": {"main": {"pipeline": ["produce_nan"]}},
    "flow_contract": {
      "common_input": [],
      "item_input": ["x"],
      "common_output": [],
      "item_output": ["x", "y"]
    }
  },
  "request": {"common": {}, "items": [{"x": 1}]},
  "expected_error": {
    "type": "ExecutionError",
    "message_contains": "NaN"
  }
