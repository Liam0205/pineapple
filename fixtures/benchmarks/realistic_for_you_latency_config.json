        "lua_script": "function compute_salt()\n    local id = user_id\n    if id == nil or id == '' or id == '0' then\n        id = client_ip or \"0\"\n    end\n    local uuid = string.match(request_id, \":(.+)$\")\n    local hex_ts = string.sub(uuid, 1, 8) .. string.sub(uuid, 10, 13)\n    local epoch = math.floor(tonumber(hex_ts, 16) / 21600000)\n    return tostring(id) .. \"|\" .. tostring(epoch) .. \"|\"\nend",
