{
  "name": "non-main single pipeline_group (fallback logic)",
  "config": {
    "pipeline_config": {
      "operators": {
        "copy_tag": {
          "type_name": "transform_copy",
          "direction": "common_to_item",
          "$metadata": {
            "common_input": ["tag"],
            "common_output": [],
            "item_input": [],
            "item_output": ["tag"]
          }
        }
      }
    },
    "pipeline_group": {
      "default_flow": {"pipeline": ["copy_tag"]}
    },
    "flow_contract": {
      "common_input": ["tag"],
      "item_input": ["id"],
      "common_output": [],
      "item_output": ["id", "tag"]
    }
  },
  "cases": [
    {
      "name": "single non-main group resolves automatically",
      "request": {
        "common": {"tag": "resolved"},
        "items": [{"id": "a"}, {"id": "b"}]
      },
      "expected": {
        "common": {},
        "items": [
          {"id": "a", "tag": "resolved"},
          {"id": "b", "tag": "resolved"}
        ]
      }
    },
    {
      "name": "empty items with non-main group",
      "request": {
        "common": {"tag": "noop"},
        "items": []
      },
      "expected": {
        "common": {},
        "items": []
      }
    }
  ]
}
