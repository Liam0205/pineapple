{
  "name": "HTML-unsafe chars and Unicode separators pass through pipeline",
  "config": {
    "pipeline_config": {
      "operators": {
        "copy_tag": {
          "type_name": "transform_copy",
          "direction": "common_to_item",
          "$metadata": {
            "common_input": [
              "tag"
            ],
            "common_output": [],
            "item_input": [],
            "item_output": [
              "tag"
            ]
          }
        }
      }
    },
    "pipeline_group": {
      "main": {
        "pipeline": [
          "copy_tag"
        ]
      }
    },
    "flow_contract": {
      "common_input": [
        "tag"
      ],
      "item_input": [
        "id"
      ],
      "common_output": [],
      "item_output": [
        "id",
        "tag"
      ]
    }
  },
  "cases": [
    {
      "name": "ampersand and angle brackets in value",
      "request": {
        "common": {
          "tag": "<b>A&B</b>"
        },
        "items": [
          {
            "id": "x1"
          }
        ]
      },
      "expected": {
        "common": {},
        "items": [
          {
            "id": "x1",
            "tag": "<b>A&B</b>"
          }
        ]
      }
    },
    {
      "name": "unicode line/paragraph separators U+2028 U+2029",
      "request": {
        "common": {
          "tag": "line para end"
        },
        "items": [
          {
            "id": "x2"
          }
        ]
      },
      "expected": {
        "common": {},
        "items": [
          {
            "id": "x2",
            "tag": "line para end"
          }
        ]
      }
    }
  ]
}
