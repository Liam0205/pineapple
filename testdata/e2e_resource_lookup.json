{
  "_PINEAPPLE_VERSION": "0.5.3",
  "pipeline_config": {
    "operators": {
      "recall": {
        "type_name": "recall_static",
        "recall": true,
        "items": [
          {"item_id": "a"},
          {"item_id": "b"},
          {"item_id": "c"}
        ],
        "$metadata": {
          "item_output": ["item_id"]
        }
      },
      "lookup": {
        "type_name": "transform_resource_lookup",
        "resource_name": "features",
        "lookup_key": "item_id",
        "output_field": "item_feature",
        "default_value": -1.0,
        "$metadata": {
          "item_input": ["item_id"],
          "item_output": ["item_feature"]
        }
      }
    },
    "pipeline_map": {
      "_main": {
        "pipeline": ["recall", "lookup"]
      }
    }
  },
  "pipeline_group": {
    "main": {
      "pipeline": ["_main"]
    }
  },
  "flow_contract": {
    "common_input": [],
    "item_input": [],
    "common_output": [],
    "item_output": ["item_id", "item_feature"]
  }
}
